{{!< default}}
{{> "pswp"}}

<main id="gh-main" class="gh-main gh-canvas">
    {{#tag}}
        <section class="gh-pagehead">
            <header class="gh-pagehead-content">
                <div class="gh-tag-label">{{t "Topic"}}</div>

                <h1 class="gh-tag-name gh-pagehead-title">{{name}}</h1>

                <div class="gh-tag-description gh-pagehead-description">
                    {{#if description}}
                        {{description}}
                    {{else}}
                        {{plural ../pagination.total 
                            empty=(t "A collection of 0 issues") singular=(t "A collection of 1 issue") 
                            plural=(t "A collection of {numberOfIssues} issues" numberOfIssues=../pagination.total) }}
                    {{/if}}
                </div>
            </header>
        </section>
    {{/tag}}
    
    <style type="text/css">
    .gh-card {
        border: 1px solid #dcdcdc; /* Light gray border */
        border-radius: 12px; /* Rounded corners */
        padding: 20px;
        background-color: white;
        width: 100%;
        /*max-width: 500px;*/
        box-shadow: 0 2px 5px rgba(0,0,0,0.1); /* Subtle shadow */
    }
    .gh-author-image {
        border-radius: 50%; /* Circular profile pic */
        height: 50px;
        width: 50px;
        max-width: fit-content;
    }
    .gh-card-header {
        display: flex;
        gap: 20px;
    }
    </style>

    <div class="gh-feed">
        {{#foreach posts}}
            {{!-- {{> loop}} --}}
            <article class="gh-card {{post_class}}">
                <header class="gh-card-header">
                    {{#primary_author}}
                        <a href="{{url}}">
                            {{#if profile_image}}
                                <img class="gh-author-image gh-pagehead-image" src="{{profile_image}}" alt="{{name}}">
                            {{else}}
                                <span class="gh-author-icon">{{> icons/avatar}}</span>
                            {{/if}}
                        </a>
                    {{/primary_author}}
                    <a class="gh-card-link" href="{{url}}">
                        <h2 class="gh-card-title">{{title}}</h2>
                        <span class="gh-card-meta">
                            <time class="gh-card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                            {{#if @site.comments_enabled}}
                                {{comment_count class="gh-card-comments"}}
                            {{/if}}
                            {{^has visibility="public"}}
                                {{> icons/star}}
                            {{/has}}
                        </span>
                    </a>
                </header>
            
                <div class="gh-content gh-canvas">
                    {{content}}
                </div>

                <footer class="gh-card-meta">
                    {{!-- <time class="gh-card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time> --}}
                    {{!-- <span class="gh-card-duration">{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span> --}}
                    
                </footer>
            </article>
        {{/foreach}}
    </div>

    <button class="gh-loadmore gh-btn">{{t "Load more issues"}}</button>
</main>